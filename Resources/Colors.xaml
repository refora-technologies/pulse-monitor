<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══════════════════════════════════════════ -->
    <!-- BRAND COLORS                               -->
    <!-- ══════════════════════════════════════════ -->
    <Color x:Key="BgDark">#0D0D0F</Color>
    <Color x:Key="BgCard">#14141A</Color>
    <Color x:Key="BgGlass">#1A1A24</Color>
    <Color x:Key="BgCardBorder">#2A2A3A</Color>
    <Color x:Key="AccentA">#00C6FF</Color>
    <Color x:Key="AccentB">#0072FF</Color>
    <Color x:Key="TextPrimary">#F0F0F5</Color>
    <Color x:Key="TextSecondary">#8888AA</Color>
    <Color x:Key="GreenNormal">#00FF87</Color>
    <Color x:Key="AmberWarm">#FFB400</Color>
    <Color x:Key="RedHot">#FF4B4B</Color>

    <!-- Solid Brushes -->
    <SolidColorBrush x:Key="BgDarkBrush"      Color="{StaticResource BgDark}"/>
    <SolidColorBrush x:Key="BgCardBrush"      Color="{StaticResource BgCard}"/>
    <SolidColorBrush x:Key="BgGlassBrush"     Color="{StaticResource BgGlass}"/>
    <SolidColorBrush x:Key="BgCardBorderBrush" Color="{StaticResource BgCardBorder}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"  Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="GreenBrush"  Color="{StaticResource GreenNormal}"/>
    <SolidColorBrush x:Key="AmberBrush"  Color="{StaticResource AmberWarm}"/>
    <SolidColorBrush x:Key="RedBrush"    Color="{StaticResource RedHot}"/>
    <SolidColorBrush x:Key="TransparentBrush" Color="Transparent"/>

    <!-- Accent Gradient -->
    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource AccentA}" Offset="0"/>
        <GradientStop Color="{StaticResource AccentB}" Offset="1"/>
    </LinearGradientBrush>

    <!-- Overlay background glass -->
    <SolidColorBrush x:Key="OverlayBgBrush" Color="#CC0D0D14"/>

</ResourceDictionary>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <FontFamily x:Key="Jakarta">pack://application:,,,/Resources/Fonts/#Plus Jakarta Sans</FontFamily>

    <!-- Surfaces -->
    <Color x:Key="BgBase">#09080F</Color>
    <Color x:Key="BgWindowTop">#15111F</Color>
    <Color x:Key="BgWindowBottom">#0B0A14</Color>
    <Color x:Key="BgCard">#16132A</Color>
    <Color x:Key="BgInset">#100D1F</Color>
    <Color x:Key="BgHover">#1E1A38</Color>
    <Color x:Key="BgElevated">#1B1734</Color>
    <Color x:Key="BorderSoft">#221E3C</Color>
    <Color x:Key="Border">#2C2750</Color>

    <!-- Violet ramp -->
    <Color x:Key="VioletDeep">#6D28D9</Color>
    <Color x:Key="Violet">#8B5CF6</Color>
    <Color x:Key="VioletLite">#A78BFA</Color>
    <Color x:Key="VioletText">#C4B5FD</Color>
    <Color x:Key="Fuchsia">#C084FC</Color>

    <!-- Text -->
    <Color x:Key="TextHi">#F4F2FC</Color>
    <Color x:Key="TextPrimary">#E5E2F4</Color>
    <Color x:Key="TextSecondary">#A6A2C6</Color>
    <Color x:Key="TextMuted">#787496</Color>
    <Color x:Key="TextDim">#54506E</Color>
    <Color x:Key="TextFaint">#3A3656</Color>

    <!-- Status -->
    <Color x:Key="GreenNormal">#3DDC97</Color>
    <Color x:Key="AmberWarm">#FFB454</Color>
    <Color x:Key="RedHot">#FF5C6C</Color>

    <!-- Legacy aliases (kept for older references) -->
    <Color x:Key="BgDark">#09080F</Color>
    <Color x:Key="BgGlass">#16132A</Color>
    <Color x:Key="BgCardBorder">#2C2750</Color>
    <Color x:Key="AccentA">#8B5CF6</Color>
    <Color x:Key="AccentB">#7C3AED</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BgBaseBrush"        Color="{StaticResource BgBase}"/>
    <SolidColorBrush x:Key="BgCardBrush"        Color="{StaticResource BgCard}"/>
    <SolidColorBrush x:Key="BgInsetBrush"       Color="{StaticResource BgInset}"/>
    <SolidColorBrush x:Key="BgElevatedBrush"    Color="{StaticResource BgElevated}"/>
    <SolidColorBrush x:Key="BgGlassBrush"       Color="{StaticResource BgCard}"/>
    <SolidColorBrush x:Key="BorderSoftBrush"    Color="{StaticResource BorderSoft}"/>
    <SolidColorBrush x:Key="BorderBrush"        Color="{StaticResource Border}"/>
    <SolidColorBrush x:Key="BgCardBorderBrush"  Color="{StaticResource Border}"/>

    <SolidColorBrush x:Key="VioletBrush"        Color="{StaticResource Violet}"/>
    <SolidColorBrush x:Key="VioletLiteBrush"    Color="{StaticResource VioletLite}"/>
    <SolidColorBrush x:Key="VioletTextBrush"    Color="{StaticResource VioletText}"/>

    <SolidColorBrush x:Key="TextHiBrush"        Color="{StaticResource TextHi}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"   Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="TextMutedBrush"     Color="{StaticResource TextMuted}"/>
    <SolidColorBrush x:Key="TextDimBrush"       Color="{StaticResource TextDim}"/>

    <SolidColorBrush x:Key="GreenBrush"  Color="{StaticResource GreenNormal}"/>
    <SolidColorBrush x:Key="AmberBrush"  Color="{StaticResource AmberWarm}"/>
    <SolidColorBrush x:Key="RedBrush"    Color="{StaticResource RedHot}"/>
    <SolidColorBrush x:Key="TransparentBrush" Color="Transparent"/>

    <!-- Brand gradient: deep violet → light violet -->
    <LinearGradientBrush x:Key="BrandGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#7C3AED" Offset="0"/>
        <GradientStop Color="#A855F7" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#7C3AED" Offset="0"/>
        <GradientStop Color="#A855F7" Offset="1"/>
    </LinearGradientBrush>

    <!-- Window backdrop gradient -->
    <LinearGradientBrush x:Key="WindowBackdrop" StartPoint="0,0" EndPoint="0.4,1">
        <GradientStop Color="{StaticResource BgWindowTop}" Offset="0"/>
        <GradientStop Color="{StaticResource BgWindowBottom}" Offset="1"/>
    </LinearGradientBrush>

</ResourceDictionary>

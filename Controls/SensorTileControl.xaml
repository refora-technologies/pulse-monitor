<UserControl x:Class="Pulse.Controls.SensorTileControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Pulse.ViewModels"
             xmlns:conv="clr-namespace:Pulse.Converters">

    <UserControl.Resources>
        <conv:PercentToWidthConverter x:Key="BarWidthConv"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <!-- Glassmorphic Tile Card -->
    <Border Style="{StaticResource TileCard}" MinWidth="100">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Category tag -->
            <TextBlock Grid.Row="0"
                       Text="{Binding Definition.Category}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="9" FontWeight="SemiBold" Opacity="0.6"
                       Margin="0,0,0,2"/>

            <!-- Label -->
            <TextBlock Grid.Row="1"
                       Text="{Binding Definition.Label}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="10.5" FontWeight="Medium"
                       Margin="0,0,0,4"/>

            <!-- Value + Unit -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                <TextBlock Text="{Binding DisplayValue}"
                           Foreground="{Binding ValueBrush}"
                           FontSize="26" FontWeight="Bold"
                           VerticalAlignment="Bottom">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.55"
                                          Color="{Binding ValueColor}"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock Text="{Binding Definition.Unit}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11" Margin="4,0,0,3"
                           VerticalAlignment="Bottom"/>
            </StackPanel>

            <!-- Progress bar (only for HasBar tiles) -->
            <Grid Grid.Row="3" Margin="0,7,0,0"
                  Visibility="{Binding Definition.HasBar, Converter={StaticResource BoolToVis}}">
                <!-- Track -->
                <Border Height="4" CornerRadius="2" Background="#2A2A3A"/>
                <!-- Fill — width driven by converter -->
                <Border x:Name="BarFill" Height="4" CornerRadius="2"
                        HorizontalAlignment="Left">
                    <Border.Width>
                        <MultiBinding Converter="{StaticResource BarWidthConv}">
                            <Binding Path="BarFraction"/>
                            <Binding RelativeSource="{RelativeSource AncestorType=Grid}"
                                     Path="ActualWidth"/>
                        </MultiBinding>
                    </Border.Width>
                    <!-- Solid brush bound to the value colour — freezable inherits DataContext -->
                    <Border.Background>
                        <SolidColorBrush Color="{Binding ValueColor}"/>
                    </Border.Background>
                </Border>
            </Grid>

        </Grid>
    </Border>
</UserControl>

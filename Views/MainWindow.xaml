<Window x:Class="Pulse.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pulse — Control Panel"
        Width="540" Height="760"
        MinWidth="460" MinHeight="580"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Icon="pack://application:,,,/Resources/Icons/pulse.ico"
        WindowStartupLocation="CenterScreen"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <FontFamily x:Key="Jakarta">pack://application:,,,/Resources/Fonts/#Plus Jakarta Sans</FontFamily>

        <!-- 5px thin scrollbar -->
        <Style x:Key="ThinScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="5"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border CornerRadius="3" Background="#322C52"
                                                    Margin="0" MinHeight="32"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0"/>
                            <ScrollBar Grid.Column="1" x:Name="PART_VerticalScrollBar"
                                       Style="{StaticResource ThinScrollBar}"
                                       Orientation="Vertical"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ TOGGLE SWITCH ═══ -->
        <Style x:Key="VioletToggle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="{StaticResource Jakarta}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Grid Width="44" Height="25" VerticalAlignment="Center">
                                <Border x:Name="Track" CornerRadius="12.5" Background="#16132A"
                                        BorderBrush="#2C2750" BorderThickness="1"/>
                                <Border x:Name="Thumb" Width="19" Height="19"
                                        CornerRadius="9.5" Background="#56527A"
                                        HorizontalAlignment="Left" Margin="3,0,0,0"
                                        VerticalAlignment="Center">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="4" ShadowDepth="0" Opacity="0.2"/>
                                    </Border.Effect>
                                </Border>
                            </Grid>
                            <ContentPresenter Margin="13,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#8B5CF6"/>
                                <Setter TargetName="Track" Property="BorderBrush" Value="#A855F7"/>
                                <Setter TargetName="Thumb" Property="Background" Value="White"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="BorderBrush" Value="#8B5CF6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ TILE TOGGLE ═══ -->
        <Style x:Key="TileToggle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="{StaticResource Jakarta}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Pill" CornerRadius="10"
                                Background="#100D1F" BorderBrush="#221E3C"
                                BorderThickness="1" Padding="11,9">
                            <StackPanel Orientation="Horizontal">
                                <Grid Width="32" Height="17" VerticalAlignment="Center" Margin="0,0,11,0">
                                    <Border x:Name="MiniTrack" CornerRadius="8.5" Background="#1A1730"/>
                                    <Border x:Name="MiniThumb" Width="13" Height="13"
                                            CornerRadius="6.5" Background="#46426A"
                                            HorizontalAlignment="Left" Margin="2,0,0,0"
                                            VerticalAlignment="Center"/>
                                </Grid>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="MiniTrack" Property="Background" Value="#8B5CF6"/>
                                <Setter TargetName="MiniThumb" Property="Background" Value="White"/>
                                <Setter TargetName="MiniThumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="MiniThumb" Property="Margin" Value="0,0,2,0"/>
                                <Setter TargetName="Pill" Property="Background" Value="#1A1336"/>
                                <Setter TargetName="Pill" Property="BorderBrush" Value="#5B3D9E"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Pill" Property="Background" Value="#171432"/>
                                <Setter TargetName="Pill" Property="BorderBrush" Value="#352F58"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ VIOLET SLIDER ═══ -->
        <Style x:Key="VioletSlider" TargetType="Slider">
            <Setter Property="Height" Value="22"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <Border Height="4" CornerRadius="2" Background="#1A1730"/>
                            <Border Height="4" CornerRadius="2" HorizontalAlignment="Stretch"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" CornerRadius="2">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                            <GradientStop Color="#7C3AED" Offset="0"/>
                                                            <GradientStop Color="#A855F7" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Grid>
                                                    <Ellipse Width="19" Height="19" Fill="White">
                                                        <Ellipse.Effect>
                                                            <DropShadowEffect Color="#8B5CF6"
                                                                BlurRadius="13" ShadowDepth="0" Opacity="0.6"/>
                                                        </Ellipse.Effect>
                                                    </Ellipse>
                                                    <Ellipse Width="8" Height="8" Fill="#8B5CF6"/>
                                                </Grid>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ PILL BUTTON ═══ -->
        <Style x:Key="PillBtn" TargetType="Button">
            <Setter Property="Background" Value="#100D1F"/>
            <Setter Property="Foreground" Value="#787496"/>
            <Setter Property="BorderBrush" Value="#221E3C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="17,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="{StaticResource Jakarta}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#171432"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#8B5CF6"/>
                                <Setter Property="Foreground" Value="#C4B5FD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ PILL BUTTON ACTIVE ═══ -->
        <Style x:Key="PillBtnActive" TargetType="Button" BasedOn="{StaticResource PillBtn}">
            <Setter Property="Background" Value="#241650"/>
            <Setter Property="Foreground" Value="#D6C9FF"/>
            <Setter Property="BorderBrush" Value="#8B5CF6"/>
        </Style>

        <!-- ═══ CORNER BUTTON ═══ -->
        <Style x:Key="CornerBtn" TargetType="Button">
            <Setter Property="Width" Value="50"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="#100D1F"/>
            <Setter Property="Foreground" Value="#56527A"/>
            <Setter Property="BorderBrush" Value="#221E3C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="9"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#171432"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#8B5CF6"/>
                                <Setter Property="Foreground" Value="#C4B5FD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ ACCENT BUTTON (small gradient) ═══ -->
        <Style x:Key="AccentBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="{StaticResource Jakarta}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="9" Padding="{TemplateBinding Padding}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#7C3AED" Offset="0"/>
                                    <GradientStop Color="#A855F7" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Border.Effect>
                                <DropShadowEffect Color="#8B5CF6" BlurRadius="14" ShadowDepth="0" Opacity="0.35"/>
                            </Border.Effect>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#A78BFA" BlurRadius="20" ShadowDepth="0" Opacity="0.55"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ TITLE BAR BUTTON ═══ -->
        <Style x:Key="TitleBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#56527A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="{StaticResource Jakarta}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#221E3C"/>
                                <Setter Property="Foreground" Value="#B6B2D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ═══ ROUNDED WINDOW SHELL ═══ -->
    <Border x:Name="WindowBorder" CornerRadius="18" BorderThickness="1"
            BorderBrush="#272346" TextElement.FontFamily="{StaticResource Jakarta}"
            TextElement.Foreground="#E5E2F4">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0.4,1">
                <GradientStop Color="#15111F" Offset="0"/>
                <GradientStop Color="#0B0A14" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="56"/>
            </Grid.RowDefinitions>

            <!-- ═══ TITLE BAR ═══ -->
            <Border Grid.Row="0" CornerRadius="17,17,0,0"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Border.Background>
                    <SolidColorBrush Color="#0E0B1C" Opacity="0.6"/>
                </Border.Background>
                <Grid Margin="22,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="PULSE" FontSize="14" FontWeight="ExtraBold"
                                   Foreground="#C4B5FD" VerticalAlignment="Center"/>
                        <TextBlock Text="  ·  Refora Technologies" FontSize="11" FontWeight="Medium"
                                   Foreground="#4C4869" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="─" Style="{StaticResource TitleBtn}" Click="BtnMinimize_Click"/>
                        <Button Content="✕" Style="{StaticResource TitleBtn}" Click="BtnClose_Click"
                                FontSize="12" Margin="2,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
            <Border Grid.Row="0" Height="1" VerticalAlignment="Bottom" Background="#201C38"/>

            <!-- ═══ SCROLL CONTENT ═══ -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="Transparent">
                <StackPanel Margin="24,22,24,12">

                    <TextBlock Text="Control Panel" FontSize="24" FontWeight="ExtraBold"
                               Foreground="#F4F2FC" Margin="0,0,0,4"/>
                    <TextBlock Text="Configure your overlay, choose sensors, and adjust style."
                               FontSize="12" FontWeight="Medium"
                               Foreground="#56527A" Margin="0,0,0,22" TextWrapping="Wrap"/>

                    <!-- ═══ UPDATE BANNER ═══ -->
                    <Border CornerRadius="13" Margin="0,0,0,22" Padding="16,13"
                            BorderThickness="1" BorderBrush="#6D28D9"
                            Visibility="{Binding ShowUpdateBanner, Converter={StaticResource BoolToVis}}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#2A1A55" Offset="0"/>
                                <GradientStop Color="#1C1340" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="#8B5CF6" BlurRadius="18" ShadowDepth="0" Opacity="0.3"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="34" Height="34" CornerRadius="9"
                                    Background="#3A2470" Margin="0,0,13,0" VerticalAlignment="Center">
                                <TextBlock Text="↑" FontSize="18" FontWeight="Bold" Foreground="#C4B5FD"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock FontSize="13.5" FontWeight="Bold" Foreground="#F4F2FC">
                                    <Run Text="New version "/><Run Text="{Binding BannerVersion, Mode=OneWay}"/><Run Text=" available"/>
                                </TextBlock>
                                <TextBlock Text="Click update to download and install the latest release."
                                           FontSize="11" FontWeight="Medium" Foreground="#9692B8" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="Update Now" Style="{StaticResource AccentBtn}"
                                    VerticalAlignment="Center" Click="BtnUpdateNow_Click"/>
                            <Button Grid.Column="3" Content="✕" Style="{StaticResource TitleBtn}"
                                    VerticalAlignment="Center" Margin="6,0,0,0" Click="BtnDismissBanner_Click"/>
                        </Grid>
                    </Border>

                    <!-- ═══ ACTIVE TILES ═══ -->
                    <Grid Margin="2,0,2,11">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="ACTIVE TILES" FontSize="10.5" FontWeight="Bold"
                                   Foreground="#56527A"/>
                        <TextBlock Grid.Column="1" FontWeight="SemiBold" FontSize="10.5">
                            <Run Text="{Binding SelectedCount, Mode=OneWay}" Foreground="#A78BFA"/>
                            <Run Text=" / 5" Foreground="#454167"/>
                        </TextBlock>
                    </Grid>
                    <Border Background="#16132A" CornerRadius="14" Padding="5,5"
                            BorderBrush="#221E3C" BorderThickness="1" Margin="0,0,0,24">
                        <ItemsControl ItemsSource="{Binding AllTiles}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><UniformGrid Columns="2"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Style="{StaticResource TileToggle}"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="3,3">
                                        <TextBlock FontSize="11.5">
                                            <Run Text="{Binding Definition.Label, Mode=OneWay}" Foreground="#E5E2F4" FontWeight="Medium"/>
                                            <Run Text=" "/>
                                            <Run Text="{Binding Definition.Unit, Mode=OneWay}" Foreground="#454167" FontSize="10"/>
                                        </TextBlock>
                                    </CheckBox>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <!-- ═══ APPEARANCE ═══ -->
                    <TextBlock Text="APPEARANCE" FontSize="10.5" FontWeight="Bold"
                               Foreground="#56527A" Margin="2,0,0,11"/>
                    <Border Background="#16132A" CornerRadius="14" Padding="22,18"
                            BorderBrush="#221E3C" BorderThickness="1" Margin="0,0,0,24">
                        <StackPanel>
                            <!-- Opacity -->
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="52"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Opacity" FontSize="13" FontWeight="SemiBold"
                                               Foreground="#E5E2F4" Margin="0,0,0,13"/>
                                    <Slider Style="{StaticResource VioletSlider}"
                                            Minimum="0.2" Maximum="1.0" SmallChange="0.05"
                                            Value="{Binding Opacity, Mode=TwoWay}"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" HorizontalAlignment="Right"
                                           VerticalAlignment="Bottom" Margin="0,0,0,1"
                                           Foreground="#A78BFA" FontSize="15" FontWeight="Bold">
                                    <Run Text="{Binding OpacityPercent, Mode=OneWay}"/>
                                    <Run Text="%" Foreground="#454167" FontSize="12"/>
                                </TextBlock>
                            </Grid>

                            <Border Height="1" Background="#201C38" Margin="0,0,0,20"/>

                            <!-- Polling Rate -->
                            <TextBlock Text="Polling Rate" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#E5E2F4" Margin="0,0,0,13"/>
                            <StackPanel x:Name="PollRatePanel" Orientation="Horizontal">
                                <Button Content="0.5s" Margin="0,0,8,0" Click="PollRate_Click" Tag="0.5"/>
                                <Button Content="1 sec" Margin="0,0,8,0" Click="PollRate_Click" Tag="1"/>
                                <Button Content="2 sec" Margin="0,0,8,0" Click="PollRate_Click" Tag="2"/>
                                <Button Content="5 sec" Click="PollRate_Click" Tag="5"/>
                            </StackPanel>

                            <Border Height="1" Background="#201C38" Margin="0,20,0,20"/>

                            <!-- Compact HUD -->
                            <CheckBox Style="{StaticResource VioletToggle}"
                                      IsChecked="{Binding IsCompactMode, Mode=TwoWay}">
                                <StackPanel>
                                    <TextBlock Text="Compact HUD Mode" FontSize="13" FontWeight="SemiBold"
                                               Foreground="#E5E2F4"/>
                                    <TextBlock Text="Minimal text overlay for in-game use"
                                               FontSize="11" FontWeight="Medium"
                                               Foreground="#56527A" Margin="0,2,0,0"/>
                                </StackPanel>
                            </CheckBox>
                        </StackPanel>
                    </Border>

                    <!-- ═══ POSITION ═══ -->
                    <TextBlock Text="POSITION" FontSize="10.5" FontWeight="Bold"
                               Foreground="#56527A" Margin="2,0,0,11"/>
                    <Border Background="#16132A" CornerRadius="14" Padding="22,18"
                            BorderBrush="#221E3C" BorderThickness="1" Margin="0,0,0,24">
                        <StackPanel>
                            <CheckBox Style="{StaticResource VioletToggle}" Margin="0,0,0,18"
                                      IsChecked="{Binding IsDragEnabled, Mode=TwoWay}">
                                <StackPanel>
                                    <TextBlock Text="Free Drag" FontSize="13" FontWeight="SemiBold"
                                               Foreground="#E5E2F4"/>
                                    <TextBlock Text="Unlock overlay to reposition freely"
                                               FontSize="11" FontWeight="Medium"
                                               Foreground="#56527A" Margin="0,2,0,0"/>
                                </StackPanel>
                            </CheckBox>
                            <Border Height="1" Background="#201C38" Margin="0,0,0,18"/>
                            <TextBlock Text="Snap to corner" FontSize="12.5" FontWeight="Medium"
                                       Foreground="#787496" Margin="0,0,0,12"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="↖" Style="{StaticResource CornerBtn}"
                                        Margin="0,0,8,0" Click="Position_Click" Tag="TopLeft"/>
                                <Button Content="↗" Style="{StaticResource CornerBtn}"
                                        Margin="0,0,8,0" Click="Position_Click" Tag="TopRight"/>
                                <Button Content="↙" Style="{StaticResource CornerBtn}"
                                        Margin="0,0,8,0" Click="Position_Click" Tag="BottomLeft"/>
                                <Button Content="↘" Style="{StaticResource CornerBtn}"
                                        Click="Position_Click" Tag="BottomRight"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ═══ SYSTEM ═══ -->
                    <TextBlock Text="SYSTEM" FontSize="10.5" FontWeight="Bold"
                               Foreground="#56527A" Margin="2,0,0,11"/>
                    <Border Background="#16132A" CornerRadius="14" Padding="22,18"
                            BorderBrush="#221E3C" BorderThickness="1" Margin="0,0,0,24">
                        <StackPanel>
                            <CheckBox Style="{StaticResource VioletToggle}" Margin="0,0,0,16"
                                      IsChecked="{Binding StartWithWindows, Mode=TwoWay}">
                                <TextBlock Text="Launch with Windows" FontSize="13" FontWeight="Medium"
                                           Foreground="#E5E2F4"/>
                            </CheckBox>
                            <CheckBox Style="{StaticResource VioletToggle}"
                                      IsChecked="{Binding MinimizeToTray, Mode=TwoWay}">
                                <TextBlock Text="Minimize to tray on close" FontSize="13" FontWeight="Medium"
                                           Foreground="#E5E2F4"/>
                            </CheckBox>
                        </StackPanel>
                    </Border>

                    <!-- ═══ UPDATES ═══ -->
                    <TextBlock Text="UPDATES" FontSize="10.5" FontWeight="Bold"
                               Foreground="#56527A" Margin="2,0,0,11"/>
                    <Border Background="#16132A" CornerRadius="14" Padding="22,18"
                            BorderBrush="#221E3C" BorderThickness="1" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Current version" FontSize="13" FontWeight="SemiBold"
                                               Foreground="#E5E2F4"/>
                                    <Border CornerRadius="6" Background="#241650" Padding="7,2" Margin="9,0,0,0">
                                        <TextBlock Text="{Binding AppVersionLabel}" FontSize="11" FontWeight="Bold"
                                                   Foreground="#C4B5FD"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="{Binding UpdateStatus}" FontSize="11" FontWeight="Medium"
                                           Foreground="#787496" Margin="0,6,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding UpdateStatus}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            <Button Grid.Column="1" x:Name="BtnCheckUpdates" Content="Check for Updates"
                                    Style="{StaticResource PillBtn}" VerticalAlignment="Center"
                                    Click="BtnCheckUpdates_Click"/>
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ═══ FOOTER ═══ -->
            <Border Grid.Row="2" BorderBrush="#201C38"
                    BorderThickness="0,1,0,0" CornerRadius="0,0,17,17">
                <Border.Background>
                    <SolidColorBrush Color="#0E0B1C" Opacity="0.6"/>
                </Border.Background>
                <Grid Margin="24,0">
                    <TextBlock VerticalAlignment="Center" Foreground="#3A3656" FontSize="10.5" FontWeight="Medium">
                        <Run Text="© 2025 Refora Technologies  ·  "/><Run Text="{Binding AppVersionLabel, Mode=OneWay}"/>
                    </TextBlock>
                    <Button x:Name="BtnOverlayToggle" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Click="BtnOverlayToggle_Click" Cursor="Hand"
                            Padding="20,10" FontWeight="Bold" FontSize="12"
                            FontFamily="{StaticResource Jakarta}"
                            Foreground="White" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" CornerRadius="11" Padding="{TemplateBinding Padding}">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#7C3AED" Offset="0"/>
                                            <GradientStop Color="#A855F7" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Border.Effect>
                                        <DropShadowEffect Color="#8B5CF6" BlurRadius="14" ShadowDepth="0" Opacity="0.3"/>
                                    </Border.Effect>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="#A78BFA" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="OverlayBtnIcon" Text="▶" FontSize="10" Margin="0,0,8,0"
                                       VerticalAlignment="Center" Foreground="White"/>
                            <TextBlock x:Name="OverlayBtnText" Text="Show Overlay"
                                       FontWeight="Bold" FontSize="12" Foreground="White"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>

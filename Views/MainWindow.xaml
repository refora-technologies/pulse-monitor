<Window x:Class="Pulse.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Pulse.Converters"
        Title="Pulse — Control Panel"
        Width="520" Height="740"
        MinWidth="460" MinHeight="580"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Icon="pack://application:,,,/Resources/Icons/pulse.ico"
        WindowStartupLocation="CenterScreen"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolConverter x:Key="InverseBool"/>
        <FontFamily x:Key="Jakarta">pack://application:,,,/Resources/Fonts/#Plus Jakarta Sans</FontFamily>
        <conv:PercentToWidthConverter x:Key="BarWidthConv"/>

        <!-- ═══ SCROLLBAR ═══ -->
        <Style x:Key="ThinScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border CornerRadius="1.5" Background="#231F3A" MinHeight="24"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0"/>
                            <ScrollBar Grid.Column="1" x:Name="PART_VerticalScrollBar"
                                       Style="{StaticResource ThinScrollBar}" Orientation="Vertical"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ TITLEBAR DOT BUTTON ═══ -->
        <Style x:Key="DotBtn" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform"><Setter.Value><ScaleTransform/></Setter.Value></Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse Width="12" Height="12" Fill="{TemplateBinding Background}"/>
                            <ContentPresenter x:Name="Symbol" HorizontalAlignment="Center"
                                              VerticalAlignment="Center" Opacity="0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Symbol" Property="Opacity" Value="1"/>
                                <Setter Property="RenderTransform">
                                    <Setter.Value><ScaleTransform ScaleX="1.12" ScaleY="1.12"/></Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value><ScaleTransform ScaleX="0.88" ScaleY="0.88"/></Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ TILE TOGGLE ═══ -->
        <Style x:Key="TileToggle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="{StaticResource Jakarta}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Pill" CornerRadius="9" BorderThickness="1" Padding="10,8">
                            <Border.Background>
                                <SolidColorBrush x:Name="PillBg" Color="#0E0C1C"/>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush x:Name="PillBdr" Color="#1C1A30"/>
                            </Border.BorderBrush>
                            <StackPanel Orientation="Horizontal">
                                <Grid Width="28" Height="15" VerticalAlignment="Center" Margin="0,0,9,0">
                                    <Border x:Name="MiniTrack" CornerRadius="7.5">
                                        <Border.Background>
                                            <SolidColorBrush x:Name="MiniTrackBg" Color="#18152C"/>
                                        </Border.Background>
                                    </Border>
                                    <Border x:Name="MiniThumb" Width="11" Height="11" CornerRadius="5.5"
                                            HorizontalAlignment="Left" Margin="2,0,0,0" VerticalAlignment="Center">
                                        <Border.Background>
                                            <SolidColorBrush x:Name="MiniThumbBg" Color="#38355C"/>
                                        </Border.Background>
                                    </Border>
                                </Grid>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ThicknessAnimation Storyboard.TargetName="MiniThumb"
                                                                Storyboard.TargetProperty="Margin"
                                                                To="15,0,0,0" Duration="0:0:0.2">
                                                <ThicknessAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </ThicknessAnimation.EasingFunction>
                                            </ThicknessAnimation>
                                            <ColorAnimation Storyboard.TargetName="MiniTrackBg"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#7C3AED" Duration="0:0:0.2"/>
                                            <ColorAnimation Storyboard.TargetName="MiniThumbBg"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#FFFFFF" Duration="0:0:0.15"/>
                                            <ColorAnimation Storyboard.TargetName="PillBg"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#160E34" Duration="0:0:0.2"/>
                                            <ColorAnimation Storyboard.TargetName="PillBdr"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#4A2898" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ThicknessAnimation Storyboard.TargetName="MiniThumb"
                                                                Storyboard.TargetProperty="Margin"
                                                                To="2,0,0,0" Duration="0:0:0.2">
                                                <ThicknessAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </ThicknessAnimation.EasingFunction>
                                            </ThicknessAnimation>
                                            <ColorAnimation Storyboard.TargetName="MiniTrackBg"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#18152C" Duration="0:0:0.2"/>
                                            <ColorAnimation Storyboard.TargetName="MiniThumbBg"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#38355C" Duration="0:0:0.15"/>
                                            <ColorAnimation Storyboard.TargetName="PillBg"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#0E0C1C" Duration="0:0:0.2"/>
                                            <ColorAnimation Storyboard.TargetName="PillBdr"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#1C1A30" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ ROW TOGGLE (label left, toggle right) ═══ -->
        <Style x:Key="RowToggle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="{StaticResource Jakarta}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ContentPresenter Grid.Column="0" VerticalAlignment="Center"
                                              HorizontalAlignment="Stretch" Margin="0,0,18,0"/>
                            <Grid Grid.Column="1" Width="42" Height="23" VerticalAlignment="Center">
                                <Border x:Name="Track" CornerRadius="11.5" BorderThickness="1">
                                    <Border.Background>
                                        <SolidColorBrush x:Name="TrackBg" Color="#12102A"/>
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <SolidColorBrush x:Name="TrackBdr" Color="#1E1B35"/>
                                    </Border.BorderBrush>
                                </Border>
                                <Border x:Name="Thumb" Width="17" Height="17" CornerRadius="8.5"
                                        HorizontalAlignment="Left" Margin="3,0,0,0" VerticalAlignment="Center">
                                    <Border.Background>
                                        <SolidColorBrush x:Name="ThumbBg" Color="#5C597E"/>
                                    </Border.Background>
                                </Border>
                            </Grid>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ThicknessAnimation Storyboard.TargetName="Thumb"
                                                                Storyboard.TargetProperty="Margin"
                                                                To="22,0,0,0" Duration="0:0:0.2">
                                                <ThicknessAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </ThicknessAnimation.EasingFunction>
                                            </ThicknessAnimation>
                                            <ColorAnimation Storyboard.TargetName="TrackBg"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#6D28D9" Duration="0:0:0.2"/>
                                            <ColorAnimation Storyboard.TargetName="TrackBdr"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#8B5CF6" Duration="0:0:0.2"/>
                                            <ColorAnimation Storyboard.TargetName="ThumbBg"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#FFFFFF" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ThicknessAnimation Storyboard.TargetName="Thumb"
                                                                Storyboard.TargetProperty="Margin"
                                                                To="3,0,0,0" Duration="0:0:0.2">
                                                <ThicknessAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </ThicknessAnimation.EasingFunction>
                                            </ThicknessAnimation>
                                            <ColorAnimation Storyboard.TargetName="TrackBg"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#12102A" Duration="0:0:0.2"/>
                                            <ColorAnimation Storyboard.TargetName="TrackBdr"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#1E1B35" Duration="0:0:0.2"/>
                                            <ColorAnimation Storyboard.TargetName="ThumbBg"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#5C597E" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ VIOLET SLIDER ═══ -->
        <Style x:Key="VioletSlider" TargetType="Slider">
            <Setter Property="Height" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <Border Height="3" CornerRadius="1.5" Background="#181430"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="3" CornerRadius="1.5">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                            <GradientStop Color="#5B21B6" Offset="0"/>
                                                            <GradientStop Color="#8B5CF6" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Grid>
                                                    <Ellipse Width="16" Height="16" Fill="White">
                                                        <Ellipse.Effect>
                                                            <DropShadowEffect Color="#7C3AED" BlurRadius="8"
                                                                              ShadowDepth="0" Opacity="0.45"/>
                                                        </Ellipse.Effect>
                                                    </Ellipse>
                                                    <Ellipse Width="6" Height="6" Fill="#7C3AED"/>
                                                </Grid>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ SEGMENT BUTTON (polling rate) ═══ -->
        <Style x:Key="SegBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#6E6B8C"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0,9"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="{StaticResource Jakarta}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform"><Setter.Value><ScaleTransform/></Setter.Value></Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="8" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#131028"/>
                                <Setter Property="Foreground" Value="#B4AEDE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value><ScaleTransform ScaleX="0.95" ScaleY="0.95"/></Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SegBtnActive" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#C4B5FD"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0,9"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="{StaticResource Jakarta}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform"><Setter.Value><ScaleTransform/></Setter.Value></Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="8" Background="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value><ScaleTransform ScaleX="0.95" ScaleY="0.95"/></Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ CORNER BUTTON ═══ -->
        <Style x:Key="CornerBtn" TargetType="Button">
            <Setter Property="Width" Value="52"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="#0E0C1C"/>
            <Setter Property="Foreground" Value="#484568"/>
            <Setter Property="BorderBrush" Value="#1C1A30"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform"><Setter.Value><ScaleTransform/></Setter.Value></Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#131028"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#5B21B6"/>
                                <Setter Property="Foreground" Value="#C4B5FD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value><ScaleTransform ScaleX="0.94" ScaleY="0.94"/></Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CornerBtnActive" TargetType="Button" BasedOn="{StaticResource CornerBtn}">
            <Setter Property="Background" Value="#1C1540"/>
            <Setter Property="Foreground" Value="#C4B5FD"/>
            <Setter Property="BorderBrush" Value="#6D28D9"/>
        </Style>

        <!-- ═══ MONITOR BUTTON ═══ -->
        <Style x:Key="MonitorBtn" TargetType="Button">
            <Setter Property="Background" Value="#0E0C1C"/>
            <Setter Property="Foreground" Value="#6E6B8C"/>
            <Setter Property="BorderBrush" Value="#1C1A30"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="13,6"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="{StaticResource Jakarta}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform"><Setter.Value><ScaleTransform/></Setter.Value></Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3A2870"/>
                                <Setter Property="Foreground" Value="#9C98C8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value><ScaleTransform ScaleX="0.96" ScaleY="0.96"/></Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="MonitorBtnActive" TargetType="Button" BasedOn="{StaticResource MonitorBtn}">
            <Setter Property="Background" Value="#1C1540"/>
            <Setter Property="Foreground" Value="#C4B5FD"/>
            <Setter Property="BorderBrush" Value="#6D28D9"/>
        </Style>

        <!-- ═══ ACCENT BUTTON ═══ -->
        <Style x:Key="AccentBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="{StaticResource Jakarta}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform"><Setter.Value><ScaleTransform/></Setter.Value></Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="9" Padding="{TemplateBinding Padding}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#5B21B6" Offset="0"/>
                                    <GradientStop Color="#7C3AED" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#6D28D9" BlurRadius="10" ShadowDepth="0" Opacity="0.3"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#8B5CF6" BlurRadius="16" ShadowDepth="0" Opacity="0.45"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value><ScaleTransform ScaleX="0.97" ScaleY="0.97"/></Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ PILL BUTTON (secondary) ═══ -->
        <Style x:Key="PillBtn" TargetType="Button">
            <Setter Property="Background" Value="#0E0C1C"/>
            <Setter Property="Foreground" Value="#6E6B8C"/>
            <Setter Property="BorderBrush" Value="#1C1A30"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="{StaticResource Jakarta}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform"><Setter.Value><ScaleTransform/></Setter.Value></Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="9"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#131028"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#5B21B6"/>
                                <Setter Property="Foreground" Value="#C4B5FD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value><ScaleTransform ScaleX="0.97" ScaleY="0.97"/></Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ═══ WINDOW SHELL ═══ -->
    <Border x:Name="WindowBorder" CornerRadius="18" BorderThickness="1"
            BorderBrush="#1C1A30" TextElement.FontFamily="{StaticResource Jakarta}"
            TextElement.Foreground="#EDE9FC">
        <Border.Background><SolidColorBrush Color="#0D0C16"/></Border.Background>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="58"/>
            </Grid.RowDefinitions>

            <!-- ═══ TITLE BAR ═══ -->
            <Border Grid.Row="0" CornerRadius="17,17,0,0" MouseLeftButtonDown="TitleBar_MouseDown">
                <Border.Background><SolidColorBrush Color="#0B0A14" Opacity="0.85"/></Border.Background>
                <Grid Margin="18,0,10,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="7" Height="7" VerticalAlignment="Center" Margin="0,0,8,0">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#C4B5FD" Offset="0"/>
                                    <GradientStop Color="#7C3AED" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <TextBlock Text="PULSE" FontSize="11.5" FontWeight="ExtraBold"
                                   Foreground="#BDB5F5" VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock Text="Monitor" FontSize="11" FontWeight="Medium"
                                   Foreground="#3C3960" VerticalAlignment="Center"/>
                    </StackPanel>
                    <!-- macOS-style dot buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Style="{StaticResource DotBtn}" Background="#FFBD2E"
                                Click="BtnMinimize_Click" Margin="0,0,4,0" ToolTip="Minimize">
                            <TextBlock Text="─" FontSize="6" FontWeight="Black" Foreground="#7F4000" Margin="0,1,0,0"/>
                        </Button>
                        <Button Style="{StaticResource DotBtn}" Background="#FF5F57"
                                Click="BtnClose_Click" ToolTip="Close">
                            <TextBlock Text="✕" FontSize="6" FontWeight="Black" Foreground="#7F0014" Margin="0,0.5,0,0"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
            <Border Grid.Row="0" Height="1" VerticalAlignment="Bottom" Background="#161330"/>

            <!-- ═══ CONTENT ═══ -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="Transparent">
                <StackPanel Margin="22,20,22,16">

                    <TextBlock Text="Control Panel" FontSize="22" FontWeight="ExtraBold"
                               Foreground="#F0EEF8" Margin="0,0,0,3"/>
                    <TextBlock Text="Configure sensors, overlay style, and preferences."
                               FontSize="11.5" FontWeight="Medium" Foreground="#524E6C"
                               Margin="0,0,0,22" TextWrapping="Wrap"/>

                    <!-- UPDATE BANNER -->
                    <Border CornerRadius="12" Margin="0,0,0,18" Padding="15,13"
                            BorderThickness="1" BorderBrush="#3D2090"
                            Visibility="{Binding ShowUpdateBanner, Converter={StaticResource BoolToVis}}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1C0E48" Offset="0"/>
                                <GradientStop Color="#110A2C" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- Icon badge -->
                            <Border Grid.Column="0" Width="34" Height="34" CornerRadius="9"
                                    Margin="0,0,13,0" VerticalAlignment="Center">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#3A1E7A" Offset="0"/>
                                        <GradientStop Color="#28145A" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                           Foreground="#A78BFA"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <!-- Text -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock FontSize="13" FontWeight="Bold" Foreground="#EDE9FC" Margin="0,0,0,3">
                                    <Run Text="{Binding BannerVersion, Mode=OneWay}"/>
                                    <Run Text=" is available"/>
                                </TextBlock>
                                <TextBlock Text="Click Update Now to download and install"
                                           FontSize="10.5" FontWeight="Medium" Foreground="#7870A8"/>
                            </StackPanel>
                            <!-- Update button -->
                            <Button Grid.Column="2" Content="Update Now" Style="{StaticResource AccentBtn}"
                                    VerticalAlignment="Center" Margin="0,0,8,0" Click="BtnUpdateNow_Click"/>
                            <!-- Dismiss -->
                            <Button Grid.Column="3" Style="{StaticResource DotBtn}" Background="#2E2A52"
                                    VerticalAlignment="Center" Click="BtnDismissBanner_Click" ToolTip="Dismiss">
                                <TextBlock Text="✕" FontSize="6" FontWeight="Black" Foreground="#6E6A94"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- DOWNLOAD PROGRESS -->
                    <Border CornerRadius="12" Margin="0,0,0,18" Padding="16,14"
                            BorderThickness="1" BorderBrush="#1E1B36"
                            Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}">
                        <Border.Background><SolidColorBrush Color="#0F0D1E"/></Border.Background>
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse Width="6" Height="6" VerticalAlignment="Center" Margin="0,0,8,0">
                                        <Ellipse.Fill><SolidColorBrush Color="#8B5CF6"/></Ellipse.Fill>
                                        <Ellipse.Effect>
                                            <DropShadowEffect x:Name="DotGlow" Color="#8B5CF6" BlurRadius="5" ShadowDepth="0" Opacity="0.5"/>
                                        </Ellipse.Effect>
                                        <Ellipse.Triggers>
                                            <EventTrigger RoutedEvent="Ellipse.Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                        <DoubleAnimation Storyboard.TargetName="DotGlow"
                                                                         Storyboard.TargetProperty="BlurRadius"
                                                                         To="16" Duration="0:0:0.9"/>
                                                        <DoubleAnimation Storyboard.TargetName="DotGlow"
                                                                         Storyboard.TargetProperty="Opacity"
                                                                         To="1.0" Duration="0:0:0.9"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Ellipse.Triggers>
                                    </Ellipse>
                                    <TextBlock Text="{Binding UpdateStatus}" FontSize="12.5"
                                               FontWeight="SemiBold" Foreground="#CEC8F8" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center"
                                           FontSize="13" FontWeight="Bold" Foreground="#7C3AED"
                                           FontFamily="Consolas">
                                    <Run Text="{Binding DownloadProgress, Mode=OneWay}"/>
                                    <Run Text="%"/>
                                </TextBlock>
                            </Grid>
                            <Grid x:Name="DownloadProgressTrack" Height="4" Margin="0,0,0,10">
                                <Border CornerRadius="2" Background="#181430"/>
                                <Border CornerRadius="2" HorizontalAlignment="Left">
                                    <Border.Width>
                                        <MultiBinding Converter="{StaticResource BarWidthConv}">
                                            <Binding Path="DownloadFraction"/>
                                            <Binding ElementName="DownloadProgressTrack" Path="ActualWidth"/>
                                        </MultiBinding>
                                    </Border.Width>
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#5B21B6" Offset="0"/>
                                            <GradientStop Color="#8B5CF6" Offset="0.7"/>
                                            <GradientStop Color="#C4B5FD" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </Grid>
                            <TextBlock Text="The installer will open automatically when ready."
                                       FontSize="10.5" FontWeight="Medium" Foreground="#4A4768"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- ══ ACTIVE TILES ══ -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE8A9;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                       Foreground="#5C597E" VerticalAlignment="Center" Margin="0,0,7,0"/>
                            <TextBlock Text="ACTIVE TILES" FontSize="10" FontWeight="Bold"
                                       Foreground="#5C597E" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" FontSize="10.5" FontWeight="SemiBold" VerticalAlignment="Center">
                            <Run Text="{Binding SelectedCount, Mode=OneWay}" Foreground="#7C5CCC"/>
                            <Run Text=" selected" Foreground="#46445E"/>
                        </TextBlock>
                    </Grid>
                    <Border Background="#111020" CornerRadius="13" Padding="5"
                            BorderBrush="#1C1A30" BorderThickness="1" Margin="0,0,0,6">
                        <ItemsControl ItemsSource="{Binding AllTiles}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><UniformGrid Columns="2"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Style="{StaticResource TileToggle}"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="3">
                                        <TextBlock FontSize="11.5">
                                            <Run Text="{Binding Definition.Label, Mode=OneWay}"
                                                 Foreground="#DBD7F2" FontWeight="Medium"/>
                                            <Run Text=" "/>
                                            <Run Text="{Binding Definition.Unit, Mode=OneWay}"
                                                 Foreground="#2E2C48" FontSize="10"/>
                                        </TextBlock>
                                    </CheckBox>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                    <TextBlock Text="Select sensors to display. The overlay updates live."
                               FontSize="10.5" Foreground="#3E3C58" FontWeight="Medium"
                               Margin="0,0,0,22" TextWrapping="Wrap"/>

                    <!-- ══ APPEARANCE ══ -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="&#xEA3A;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                   Foreground="#5C597E" VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock Text="APPEARANCE" FontSize="10" FontWeight="Bold"
                                   Foreground="#5C597E" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Border Background="#111020" CornerRadius="13" BorderBrush="#1C1A30"
                            BorderThickness="1" Margin="0,0,0,22">
                        <StackPanel>

                            <!-- Opacity -->
                            <StackPanel Margin="18,15,18,15">
                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="Opacity" FontSize="13" FontWeight="SemiBold" Foreground="#DBD7F2"/>
                                    <TextBlock HorizontalAlignment="Right" FontSize="15" FontWeight="Bold" Foreground="#7C5CCC">
                                        <Run Text="{Binding OpacityPercent, Mode=OneWay}"/>
                                        <Run Text="%" Foreground="#42406A" FontSize="11"/>
                                    </TextBlock>
                                </Grid>
                                <TextBlock Text="How visible the overlay is over your games"
                                           FontSize="10.5" FontWeight="Medium" Foreground="#4E4A6C" Margin="0,0,0,12"/>
                                <Slider Style="{StaticResource VioletSlider}"
                                        Minimum="0.2" Maximum="1.0" SmallChange="0.05"
                                        Value="{Binding Opacity, Mode=TwoWay}"/>
                            </StackPanel>

                            <Border Height="1" Background="#131128"/>

                            <!-- Polling Rate (segmented control) -->
                            <StackPanel Margin="18,14,18,14">
                                <TextBlock Text="Polling Rate" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#DBD7F2" Margin="0,0,0,2"/>
                                <TextBlock Text="How often sensor values refresh"
                                           FontSize="10.5" FontWeight="Medium" Foreground="#4E4A6C" Margin="0,0,0,12"/>
                                <Border Background="#0A0918" CornerRadius="10"
                                        BorderBrush="#181530" BorderThickness="1" Padding="3">
                                    <Grid>
                                        <!-- Sliding active indicator (behind buttons) -->
                                        <Border x:Name="SegIndicator" HorizontalAlignment="Left"
                                                VerticalAlignment="Stretch" Background="#1C1540" CornerRadius="8">
                                            <Border.RenderTransform>
                                                <TranslateTransform x:Name="SegIndicatorTranslate"/>
                                            </Border.RenderTransform>
                                        </Border>
                                        <Grid x:Name="PollRatePanel">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Content="0.5s" Style="{StaticResource SegBtn}"
                                                    Tag="0.5" Click="PollRate_Click"/>
                                            <Button Grid.Column="1" Content="1 sec" Style="{StaticResource SegBtn}"
                                                    Tag="1" Click="PollRate_Click"/>
                                            <Button Grid.Column="2" Content="2 sec" Style="{StaticResource SegBtn}"
                                                    Tag="2" Click="PollRate_Click"/>
                                            <Button Grid.Column="3" Content="5 sec" Style="{StaticResource SegBtn}"
                                                    Tag="5" Click="PollRate_Click"/>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <Border Height="1" Background="#131128"/>

                            <!-- Compact HUD -->
                            <CheckBox Style="{StaticResource RowToggle}" Margin="18,14,18,14"
                                      IsChecked="{Binding IsCompactMode, Mode=TwoWay}">
                                <StackPanel>
                                    <TextBlock Text="Compact HUD" FontSize="13" FontWeight="SemiBold"
                                               Foreground="#DBD7F2" Margin="0,0,0,2"/>
                                    <TextBlock Text="Minimal list — values only, no bars"
                                               FontSize="10.5" FontWeight="Medium" Foreground="#4E4A6C"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </CheckBox>

                            <Border Height="1" Background="#131128"/>

                            <!-- Status Bar -->
                            <CheckBox Style="{StaticResource RowToggle}" Margin="18,14,18,14"
                                      IsChecked="{Binding ShowStatusBar, Mode=TwoWay}">
                                <StackPanel>
                                    <TextBlock Text="Status Bar" FontSize="13" FontWeight="SemiBold"
                                               Foreground="#DBD7F2" Margin="0,0,0,2"/>
                                    <TextBlock Text="Health summary at the bottom of the overlay"
                                               FontSize="10.5" FontWeight="Medium" Foreground="#4E4A6C"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </CheckBox>
                        </StackPanel>
                    </Border>

                    <!-- ══ POSITION ══ -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="&#xE759;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                   Foreground="#5C597E" VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock Text="POSITION" FontSize="10" FontWeight="Bold"
                                   Foreground="#5C597E" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Border Background="#111020" CornerRadius="13" BorderBrush="#1C1A30"
                            BorderThickness="1" Margin="0,0,0,22">
                        <StackPanel>
                            <CheckBox Style="{StaticResource RowToggle}" Margin="18,14,18,14"
                                      IsChecked="{Binding IsDragEnabled, Mode=TwoWay}">
                                <StackPanel>
                                    <TextBlock Text="Free Drag" FontSize="13" FontWeight="SemiBold"
                                               Foreground="#DBD7F2" Margin="0,0,0,2"/>
                                    <TextBlock Text="Unlock the overlay to drag it anywhere on screen"
                                               FontSize="10.5" FontWeight="Medium" Foreground="#4E4A6C"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </CheckBox>
                            <Border Height="1" Background="#131128"/>
                            <StackPanel Margin="18,14,18,16">
                                <!-- Monitor selection (hidden when only 1 display) -->
                                <Grid x:Name="MonitorSelectionRow" Margin="0,0,0,14"
                                      Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Display" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="#DBD7F2" Margin="0,0,0,2"/>
                                        <TextBlock Text="Which monitor to place the overlay on"
                                                   FontSize="10.5" FontWeight="Medium"
                                                   Foreground="#4E4A6C"/>
                                    </StackPanel>
                                    <StackPanel x:Name="MonitorPanel" Grid.Column="1"
                                                Orientation="Horizontal" VerticalAlignment="Center"/>
                                </Grid>

                                <TextBlock Text="Snap to corner" FontSize="12" FontWeight="SemiBold"
                                           Foreground="#6E6B8C" Margin="0,0,0,10"/>
                                <StackPanel x:Name="PositionPanel" Orientation="Horizontal">
                                    <Button Style="{StaticResource CornerBtn}"
                                            Click="Position_Click" Tag="TopLeft" Margin="0,0,8,0">
                                        <Path Data="M 13,13 L 2,2 L 8,2 M 2,2 L 2,8"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                              Width="16" Height="16"/>
                                    </Button>
                                    <Button Style="{StaticResource CornerBtn}"
                                            Click="Position_Click" Tag="TopRight" Margin="0,0,8,0">
                                        <Path Data="M 2,13 L 13,2 L 7,2 M 13,2 L 13,8"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                              Width="16" Height="16"/>
                                    </Button>
                                    <Button Style="{StaticResource CornerBtn}"
                                            Click="Position_Click" Tag="BottomLeft" Margin="0,0,8,0">
                                        <Path Data="M 13,2 L 2,13 L 8,13 M 2,13 L 2,7"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                              Width="16" Height="16"/>
                                    </Button>
                                    <Button Style="{StaticResource CornerBtn}"
                                            Click="Position_Click" Tag="BottomRight">
                                        <Path Data="M 2,2 L 13,13 L 7,13 M 13,13 L 13,7"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                              Width="16" Height="16"/>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ══ SYSTEM ══ -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                   Foreground="#5C597E" VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock Text="SYSTEM" FontSize="10" FontWeight="Bold"
                                   Foreground="#5C597E" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Border Background="#111020" CornerRadius="13" BorderBrush="#1C1A30"
                            BorderThickness="1" Margin="0,0,0,22">
                        <StackPanel>
                            <CheckBox Style="{StaticResource RowToggle}" Margin="18,14,18,14"
                                      IsChecked="{Binding StartWithWindows, Mode=TwoWay}">
                                <StackPanel>
                                    <TextBlock Text="Launch with Windows" FontSize="13" FontWeight="SemiBold"
                                               Foreground="#DBD7F2" Margin="0,0,0,2"/>
                                    <TextBlock Text="Pulse starts automatically when you sign in"
                                               FontSize="10.5" FontWeight="Medium" Foreground="#4E4A6C"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </CheckBox>
                            <Border Height="1" Background="#131128"/>
                            <CheckBox Style="{StaticResource RowToggle}" Margin="18,14,18,14"
                                      IsChecked="{Binding MinimizeToTray, Mode=TwoWay}">
                                <StackPanel>
                                    <TextBlock Text="Minimize to tray" FontSize="13" FontWeight="SemiBold"
                                               Foreground="#DBD7F2" Margin="0,0,0,2"/>
                                    <TextBlock Text="Closing keeps Pulse running in the system tray"
                                               FontSize="10.5" FontWeight="Medium" Foreground="#4E4A6C"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </CheckBox>
                        </StackPanel>
                    </Border>

                    <!-- ══ UPDATES ══ -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                   Foreground="#5C597E" VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock Text="UPDATES" FontSize="10" FontWeight="Bold"
                                   Foreground="#5C597E" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Border Background="#111020" CornerRadius="13" Padding="18,16"
                            BorderBrush="#1C1A30" BorderThickness="1" Margin="0,0,0,8">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                        <TextBlock Text="Version" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="#DBD7F2" Margin="0,0,8,0"/>
                                        <Border CornerRadius="5" Background="#16103A" Padding="7,2">
                                            <TextBlock Text="{Binding AppVersionLabel}" FontSize="11"
                                                       FontWeight="Bold" Foreground="#8B5CF6"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding UpdateStatus}" FontSize="10.5"
                                               FontWeight="Medium" Foreground="#6E6B8C">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding UpdateStatus}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                                <Button Grid.Column="1" x:Name="BtnCheckUpdates"
                                        Style="{StaticResource PillBtn}" VerticalAlignment="Center"
                                        IsEnabled="{Binding IsCheckingUpdate, Converter={StaticResource InverseBool}}"
                                        Click="BtnCheckUpdates_Click">
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Check for updates"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCheckingUpdate}" Value="True">
                                                        <Setter Property="Text" Value="Checking…"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Button>
                            </Grid>
                            <TextBlock Text="Pulse checks automatically on startup"
                                       FontSize="10.5" FontWeight="Medium" Foreground="#524E6C"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ═══ FOOTER ═══ -->
            <Border Grid.Row="2" BorderBrush="#161330" BorderThickness="0,1,0,0" CornerRadius="0,0,17,17">
                <Border.Background><SolidColorBrush Color="#0B0A14" Opacity="0.9"/></Border.Background>
                <Grid Margin="20,0">
                    <TextBlock VerticalAlignment="Center" Foreground="#6E6B8C"
                               FontSize="10.5" FontWeight="Medium">
                        <Run Text="© 2026 Refora Technologies  ·  "/>
                        <Run Text="{Binding AppVersionLabel, Mode=OneWay}"/>
                    </TextBlock>
                    <Button x:Name="BtnOverlayToggle" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Click="BtnOverlayToggle_Click" Cursor="Hand" Padding="20,11"
                            FontWeight="Bold" FontSize="12" FontFamily="{StaticResource Jakarta}"
                            Foreground="White" BorderThickness="0" RenderTransformOrigin="0.5,0.5">
                        <Button.RenderTransform><ScaleTransform/></Button.RenderTransform>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" CornerRadius="11" Padding="{TemplateBinding Padding}">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#5B21B6" Offset="0"/>
                                            <GradientStop Color="#7C3AED" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect Color="#6D28D9" BlurRadius="12" ShadowDepth="0" Opacity="0.28"/>
                                    </Border.Effect>
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="#8B5CF6" BlurRadius="18" ShadowDepth="0" Opacity="0.45"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="RenderTransform">
                                            <Setter.Value><ScaleTransform ScaleX="0.97" ScaleY="0.97"/></Setter.Value>
                                        </Setter>
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="OverlayBtnIcon" Text="▶" FontSize="10"
                                       VerticalAlignment="Center" Foreground="White" Margin="0,0,8,0"/>
                            <TextBlock x:Name="OverlayBtnText" Text="Show Overlay"
                                       FontWeight="Bold" FontSize="12" Foreground="White"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>

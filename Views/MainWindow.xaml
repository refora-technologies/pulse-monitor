<Window x:Class="Pulse.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pulse — Control Panel"
        Width="520" Height="720"
        MinWidth="460" MinHeight="580"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Icon="pack://application:,,,/Resources/Icons/pulse.ico"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Ubuntu font family -->
        <FontFamily x:Key="Ubuntu">pack://application:,,,/Resources/Fonts/#Ubuntu</FontFamily>
        <FontFamily x:Key="UbuntuMedium">pack://application:,,,/Resources/Fonts/#Ubuntu Medium</FontFamily>
        <FontFamily x:Key="UbuntuBold">pack://application:,,,/Resources/Fonts/#Ubuntu Bold</FontFamily>
        <FontFamily x:Key="UbuntuLight">pack://application:,,,/Resources/Fonts/#Ubuntu Light</FontFamily>

        <!-- 4px thin scrollbar -->
        <Style x:Key="ThinScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border CornerRadius="2" Background="#2A2A4A"
                                                    Margin="0" MinHeight="30" Opacity="0.5"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0"/>
                            <ScrollBar Grid.Column="1" x:Name="PART_VerticalScrollBar"
                                       Style="{StaticResource ThinScrollBar}"
                                       Orientation="Vertical"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ TOGGLE SWITCH ═══ -->
        <Style x:Key="VioletToggle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="{StaticResource Ubuntu}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Grid Width="42" Height="24" VerticalAlignment="Center">
                                <Border x:Name="Track" CornerRadius="12" Background="#181A30"
                                        BorderBrush="#252748" BorderThickness="1"/>
                                <Border x:Name="Thumb" Width="18" Height="18"
                                        CornerRadius="9" Background="#4A4C6A"
                                        HorizontalAlignment="Left" Margin="3,0,0,0"
                                        VerticalAlignment="Center">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="3" ShadowDepth="0" Opacity="0.15"/>
                                    </Border.Effect>
                                </Border>
                            </Grid>
                            <ContentPresenter Margin="12,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#8B5CF6"/>
                                <Setter TargetName="Track" Property="BorderBrush" Value="#7C3AED"/>
                                <Setter TargetName="Thumb" Property="Background" Value="White"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="BorderBrush" Value="#8B5CF6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ TILE TOGGLE ═══ -->
        <Style x:Key="TileToggle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="{StaticResource Ubuntu}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Pill" CornerRadius="8"
                                Background="#0E1028" BorderBrush="#1C1E3A"
                                BorderThickness="1" Padding="10,8">
                            <StackPanel Orientation="Horizontal">
                                <Grid Width="30" Height="16" VerticalAlignment="Center" Margin="0,0,10,0">
                                    <Border x:Name="MiniTrack" CornerRadius="8" Background="#181A30"/>
                                    <Border x:Name="MiniThumb" Width="12" Height="12"
                                            CornerRadius="6" Background="#3A3C5A"
                                            HorizontalAlignment="Left" Margin="2,0,0,0"
                                            VerticalAlignment="Center"/>
                                </Grid>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="MiniTrack" Property="Background" Value="#8B5CF6"/>
                                <Setter TargetName="MiniThumb" Property="Background" Value="White"/>
                                <Setter TargetName="MiniThumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="MiniThumb" Property="Margin" Value="0,0,2,0"/>
                                <Setter TargetName="Pill" Property="BorderBrush" Value="#2E1065"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Pill" Property="Background" Value="#121430"/>
                                <Setter TargetName="Pill" Property="BorderBrush" Value="#2A2C50"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ VIOLET SLIDER ═══ -->
        <Style x:Key="VioletSlider" TargetType="Slider">
            <Setter Property="Height" Value="22"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <Border Height="3" CornerRadius="2" Background="#1C1E3A"/>
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Grid>
                                                    <Ellipse Width="18" Height="18" Fill="#8B5CF6">
                                                        <Ellipse.Effect>
                                                            <DropShadowEffect Color="#8B5CF6"
                                                                BlurRadius="12" ShadowDepth="0" Opacity="0.5"/>
                                                        </Ellipse.Effect>
                                                    </Ellipse>
                                                    <Ellipse Width="7" Height="7" Fill="White"/>
                                                </Grid>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ PILL BUTTON ═══ -->
        <Style x:Key="PillBtn" TargetType="Button">
            <Setter Property="Background" Value="#0E1028"/>
            <Setter Property="Foreground" Value="#6B6D8A"/>
            <Setter Property="BorderBrush" Value="#1C1E3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontFamily" Value="{StaticResource Ubuntu}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#161838"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#8B5CF6"/>
                                <Setter Property="Foreground" Value="#C4B5FD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ PILL BUTTON ACTIVE ═══ -->
        <Style x:Key="PillBtnActive" TargetType="Button" BasedOn="{StaticResource PillBtn}">
            <Setter Property="Background" Value="#1E1048"/>
            <Setter Property="Foreground" Value="#C4B5FD"/>
            <Setter Property="BorderBrush" Value="#8B5CF6"/>
        </Style>

        <!-- ═══ CORNER BUTTON ═══ -->
        <Style x:Key="CornerBtn" TargetType="Button">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="#0E1028"/>
            <Setter Property="Foreground" Value="#4A4C6A"/>
            <Setter Property="BorderBrush" Value="#1C1E3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#161838"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#8B5CF6"/>
                                <Setter Property="Foreground" Value="#C4B5FD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ TITLE BAR BUTTON ═══ -->
        <Style x:Key="TitleBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#3A3C5A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="{StaticResource Ubuntu}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1C1E3A"/>
                                <Setter Property="Foreground" Value="#A0A2C0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ═══ ROUNDED WINDOW SHELL ═══ -->
    <Border x:Name="WindowBorder" CornerRadius="16" Background="#0B0D1A"
            BorderBrush="#1C1E3A" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="52"/>
            </Grid.RowDefinitions>

            <!-- ═══ TITLE BAR ═══ -->
            <Border Grid.Row="0" Background="#0E1025" CornerRadius="15,15,0,0"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="20,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="PULSE" FontSize="13" FontWeight="Bold"
                                   FontFamily="{StaticResource UbuntuBold}"
                                   Foreground="#A78BFA" VerticalAlignment="Center"/>
                        <TextBlock Text="  ·  Refora Technologies" FontSize="10.5"
                                   FontFamily="{StaticResource Ubuntu}"
                                   Foreground="#3A3C5A" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="─" Style="{StaticResource TitleBtn}" Click="BtnMinimize_Click"/>
                        <Button Content="✕" Style="{StaticResource TitleBtn}" Click="BtnClose_Click"
                                FontSize="12" Margin="2,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
            <Border Grid.Row="0" Height="1" VerticalAlignment="Bottom" Background="#181A30"/>

            <!-- ═══ SCROLL CONTENT ═══ -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="Transparent">
                <StackPanel Margin="22,20,22,10">

                    <TextBlock Text="Control Panel" FontSize="22" FontWeight="Bold"
                               FontFamily="{StaticResource UbuntuBold}"
                               Foreground="#E2E4F0" Margin="0,0,0,3"/>
                    <TextBlock Text="Configure your overlay, choose sensors, and adjust style."
                               FontSize="11.5" FontFamily="{StaticResource Ubuntu}"
                               Foreground="#4A4C6A" Margin="0,0,0,26" TextWrapping="Wrap"/>

                    <!-- ═══ ACTIVE TILES ═══ -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="ACTIVE TILES" FontSize="10" FontWeight="Bold"
                                   FontFamily="{StaticResource UbuntuBold}" Foreground="#3A3C5A"/>
                        <TextBlock Grid.Column="1" FontFamily="{StaticResource Ubuntu}"
                                   Foreground="#3A3C5A" FontSize="10">
                            <Run Text="{Binding SelectedCount, Mode=OneWay}" Foreground="#A78BFA"/>
                            <Run Text=" / 5"/>
                        </TextBlock>
                    </Grid>
                    <Border Background="#0E1028" CornerRadius="12" Padding="4,4"
                            BorderBrush="#1C1E3A" BorderThickness="1" Margin="0,0,0,26">
                        <ItemsControl ItemsSource="{Binding AllTiles}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><UniformGrid Columns="2"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Style="{StaticResource TileToggle}"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="3,3">
                                        <TextBlock FontSize="11.5" FontFamily="{StaticResource Ubuntu}">
                                            <Run Text="{Binding Definition.Label, Mode=OneWay}" Foreground="#E2E4F0"/>
                                            <Run Text=" "/>
                                            <Run Text="{Binding Definition.Unit, Mode=OneWay}" Foreground="#3A3C5A" FontSize="10"/>
                                        </TextBlock>
                                    </CheckBox>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <!-- ═══ APPEARANCE ═══ -->
                    <TextBlock Text="APPEARANCE" FontSize="10" FontWeight="Bold"
                               FontFamily="{StaticResource UbuntuBold}" Foreground="#3A3C5A" Margin="0,0,0,10"/>
                    <Border Background="#0E1028" CornerRadius="12" Padding="20,16"
                            BorderBrush="#1C1E3A" BorderThickness="1" Margin="0,0,0,26">
                        <StackPanel>
                            <!-- Opacity -->
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="48"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Opacity" FontSize="13" FontWeight="Medium"
                                               FontFamily="{StaticResource UbuntuMedium}"
                                               Foreground="#E2E4F0" Margin="0,0,0,12"/>
                                    <Slider Style="{StaticResource VioletSlider}"
                                            Minimum="0.2" Maximum="1.0" SmallChange="0.05"
                                            Value="{Binding Opacity, Mode=TwoWay}"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" HorizontalAlignment="Right"
                                           VerticalAlignment="Bottom" Margin="0,0,0,2"
                                           FontFamily="{StaticResource UbuntuBold}"
                                           Foreground="#A78BFA" FontSize="14" FontWeight="Bold">
                                    <Run Text="{Binding OpacityPercent, Mode=OneWay}"/>
                                    <Run Text="%" Foreground="#3A3C5A"/>
                                </TextBlock>
                            </Grid>

                            <Border Height="1" Background="#1C1E3A" Margin="0,0,0,20"/>

                            <!-- Polling Rate -->
                            <TextBlock Text="Polling Rate" FontSize="13" FontWeight="Medium"
                                       FontFamily="{StaticResource UbuntuMedium}"
                                       Foreground="#E2E4F0" Margin="0,0,0,12"/>
                            <StackPanel x:Name="PollRatePanel" Orientation="Horizontal">
                                <Button Content="0.5s" Margin="0,0,8,0"
                                        Click="PollRate_Click" Tag="0.5"/>
                                <Button Content="1 sec" Margin="0,0,8,0"
                                        Click="PollRate_Click" Tag="1"/>
                                <Button Content="2 sec" Margin="0,0,8,0"
                                        Click="PollRate_Click" Tag="2"/>
                                <Button Content="5 sec"
                                        Click="PollRate_Click" Tag="5"/>
                            </StackPanel>

                            <Border Height="1" Background="#1C1E3A" Margin="20,20,0,20"/>

                            <!-- Compact HUD -->
                            <CheckBox Style="{StaticResource VioletToggle}"
                                      IsChecked="{Binding IsCompactMode, Mode=TwoWay}">
                                <StackPanel>
                                    <TextBlock Text="Compact HUD Mode" FontSize="13" FontWeight="Medium"
                                               FontFamily="{StaticResource UbuntuMedium}" Foreground="#E2E4F0"/>
                                    <TextBlock Text="Minimal text overlay for in-game use"
                                               FontSize="10.5" FontFamily="{StaticResource Ubuntu}"
                                               Foreground="#4A4C6A" Margin="0,2,0,0"/>
                                </StackPanel>
                            </CheckBox>
                        </StackPanel>
                    </Border>

                    <!-- ═══ POSITION ═══ -->
                    <TextBlock Text="POSITION" FontSize="10" FontWeight="Bold"
                               FontFamily="{StaticResource UbuntuBold}" Foreground="#3A3C5A" Margin="0,0,0,10"/>
                    <Border Background="#0E1028" CornerRadius="12" Padding="20,16"
                            BorderBrush="#1C1E3A" BorderThickness="1" Margin="0,0,0,26">
                        <StackPanel>
                            <CheckBox Style="{StaticResource VioletToggle}" Margin="0,0,0,16"
                                      IsChecked="{Binding IsDragEnabled, Mode=TwoWay}">
                                <StackPanel>
                                    <TextBlock Text="Free Drag" FontSize="13" FontWeight="Medium"
                                               FontFamily="{StaticResource UbuntuMedium}" Foreground="#E2E4F0"/>
                                    <TextBlock Text="Unlock overlay to reposition freely"
                                               FontSize="10.5" FontFamily="{StaticResource Ubuntu}"
                                               Foreground="#4A4C6A" Margin="0,2,0,0"/>
                                </StackPanel>
                            </CheckBox>
                            <Border Height="1" Background="#1C1E3A" Margin="0,0,0,16"/>
                            <TextBlock Text="Snap to corner" FontSize="12"
                                       FontFamily="{StaticResource Ubuntu}"
                                       Foreground="#4A4C6A" Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="↖" Style="{StaticResource CornerBtn}"
                                        Margin="0,0,6,0" Click="Position_Click" Tag="TopLeft"/>
                                <Button Content="↗" Style="{StaticResource CornerBtn}"
                                        Margin="0,0,6,0" Click="Position_Click" Tag="TopRight"/>
                                <Button Content="↙" Style="{StaticResource CornerBtn}"
                                        Margin="0,0,6,0" Click="Position_Click" Tag="BottomLeft"/>
                                <Button Content="↘" Style="{StaticResource CornerBtn}"
                                        Click="Position_Click" Tag="BottomRight"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ═══ SYSTEM ═══ -->
                    <TextBlock Text="SYSTEM" FontSize="10" FontWeight="Bold"
                               FontFamily="{StaticResource UbuntuBold}" Foreground="#3A3C5A" Margin="0,0,0,10"/>
                    <Border Background="#0E1028" CornerRadius="12" Padding="20,16"
                            BorderBrush="#1C1E3A" BorderThickness="1" Margin="0,0,0,26">
                        <StackPanel>
                            <CheckBox Style="{StaticResource VioletToggle}" Margin="0,0,0,16"
                                      IsChecked="{Binding StartWithWindows, Mode=TwoWay}">
                                <TextBlock Text="Launch with Windows" FontSize="13"
                                           FontFamily="{StaticResource Ubuntu}" Foreground="#E2E4F0"/>
                            </CheckBox>
                            <CheckBox Style="{StaticResource VioletToggle}"
                                      IsChecked="{Binding MinimizeToTray, Mode=TwoWay}">
                                <TextBlock Text="Minimize to tray on close" FontSize="13"
                                           FontFamily="{StaticResource Ubuntu}" Foreground="#E2E4F0"/>
                            </CheckBox>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ═══ FOOTER ═══ -->
            <Border Grid.Row="2" Background="#0E1025" BorderBrush="#181A30"
                    BorderThickness="0,1,0,0" CornerRadius="0,0,15,15">
                <Grid Margin="22,0">
                    <TextBlock Text="© 2025 Refora Technologies  ·  v1.0" VerticalAlignment="Center"
                               FontFamily="{StaticResource Ubuntu}" Foreground="#2A2C48" FontSize="10"/>
                    <Button x:Name="BtnOverlayToggle" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Click="BtnOverlayToggle_Click" Cursor="Hand"
                            Padding="18,9" FontWeight="Bold" FontSize="12"
                            FontFamily="{StaticResource UbuntuMedium}"
                            Foreground="White" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" CornerRadius="10" Padding="{TemplateBinding Padding}">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#7C3AED" Offset="0"/>
                                            <GradientStop Color="#8B5CF6" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Border.Effect>
                                        <DropShadowEffect Color="#8B5CF6" BlurRadius="12" ShadowDepth="0" Opacity="0.25"/>
                                    </Border.Effect>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="#A78BFA" BlurRadius="18" ShadowDepth="0" Opacity="0.45"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="OverlayBtnIcon" Text="▶" FontSize="10" Margin="0,0,8,0"
                                       VerticalAlignment="Center" Foreground="White"/>
                            <TextBlock x:Name="OverlayBtnText" Text="Show Overlay"
                                       FontWeight="Bold" FontSize="12"
                                       FontFamily="{StaticResource UbuntuMedium}" Foreground="White"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>

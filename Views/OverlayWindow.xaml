<Window x:Class="Pulse.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Pulse.ViewModels"
        Title="Pulse Overlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Icon="pack://application:,,,/Resources/Icons/pulse.ico"
        SizeToContent="WidthAndHeight"
        Opacity="{Binding OverlayOpacity}"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <FontFamily x:Key="Jakarta">pack://application:,,,/Resources/Fonts/#Plus Jakarta Sans</FontFamily>
    </Window.Resources>

    <Border x:Name="DragBorder" Padding="6" TextElement.FontFamily="{StaticResource Jakarta}">
        <Grid>
            <!-- ═══ NORMAL MODE ═══ -->
            <Border x:Name="NormalPanel" CornerRadius="18"
                    MinWidth="288" MaxWidth="334"
                    BorderThickness="1">
                <Border.BorderBrush>
                    <SolidColorBrush Color="#8B5CF6" Opacity="0.22"/>
                </Border.BorderBrush>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0.5,1">
                        <GradientStop Color="#17122C" Offset="0"/>
                        <GradientStop Color="#0C0A18" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="28" ShadowDepth="8" Opacity="0.5" Direction="270"/>
                </Border.Effect>

                <StackPanel Margin="16,14,16,12">
                    <!-- Header -->
                    <Grid Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Ellipse.Fill>
                                    <SolidColorBrush Color="{Binding StatusColor}"/>
                                </Ellipse.Fill>
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="9" ShadowDepth="0" Opacity="0.95"
                                                      Color="{Binding StatusColor}"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <TextBlock Text="PULSE" FontSize="12" FontWeight="ExtraBold"
                                       Foreground="#C4B5FD" VerticalAlignment="Center"/>
                            <TextBlock Text="MONITOR" FontSize="9.5" FontWeight="SemiBold"
                                       Foreground="#5A5578" VerticalAlignment="Center"
                                       Margin="6,1,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Accent divider -->
                    <Border Height="1.5" Margin="0,0,0,12" CornerRadius="1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#A855F7" Offset="0"/>
                                <GradientStop Color="#3A2D5C" Offset="0.55"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Sensor tiles — 2 column grid -->
                    <ItemsControl ItemsSource="{Binding ActiveTiles}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:TileViewModel}">
                                <Border CornerRadius="12" Margin="3,3" Padding="13,9,13,10"
                                        BorderThickness="1">
                                    <Border.Background>
                                        <SolidColorBrush Color="#1A1632"/>
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <SolidColorBrush Color="#2A2548"/>
                                    </Border.BorderBrush>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Definition.Label}"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   Foreground="#928EB4" Margin="0,0,0,5"/>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                                            <TextBlock Text="{Binding DisplayValue}"
                                                       FontSize="23" FontWeight="Bold"
                                                       Foreground="{Binding ValueBrush}"/>
                                            <TextBlock FontSize="11" Foreground="#8E8AB0"
                                                       FontWeight="Medium"
                                                       VerticalAlignment="Bottom" Margin="4,0,0,3">
                                                <Run Text="{Binding Definition.Unit, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Status bar -->
                    <Border Height="1" Margin="0,8,0,9">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#2A2548" Offset="0.5"/>
                                <GradientStop Color="#7C3AED" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="6" Height="6" VerticalAlignment="Center" Margin="0,0,7,0">
                            <Ellipse.Fill>
                                <SolidColorBrush Color="{Binding StatusColor}"/>
                            </Ellipse.Fill>
                            <Ellipse.Effect>
                                <DropShadowEffect BlurRadius="6" ShadowDepth="0" Opacity="0.7"
                                                  Color="{Binding StatusColor}"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusBrush}"
                                   FontSize="10.5" FontWeight="Medium"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ═══ COMPACT HUD MODE ═══ -->
            <Border x:Name="CompactPanel" CornerRadius="12" Visibility="Collapsed" MinWidth="172"
                    BorderThickness="1">
                <Border.BorderBrush>
                    <SolidColorBrush Color="#8B5CF6" Opacity="0.18"/>
                </Border.BorderBrush>
                <Border.Background>
                    <SolidColorBrush Color="#0C0A18" Opacity="0.82"/>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="16" ShadowDepth="4" Opacity="0.45" Direction="270"/>
                </Border.Effect>

                <StackPanel Margin="14,10,14,9">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,7">
                        <Ellipse Width="6" Height="6" Margin="0,0,6,0" VerticalAlignment="Center">
                            <Ellipse.Fill>
                                <SolidColorBrush Color="{Binding StatusColor}"/>
                            </Ellipse.Fill>
                            <Ellipse.Effect>
                                <DropShadowEffect BlurRadius="6" ShadowDepth="0" Opacity="0.8"
                                                  Color="{Binding StatusColor}"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <TextBlock Text="PULSE" FontSize="9" FontWeight="ExtraBold"
                                   Foreground="#7C77A0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding ActiveTiles}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:TileViewModel}">
                                <Grid Margin="0,2.5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="54"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Definition.Label}"
                                               FontSize="11" FontWeight="Medium"
                                               Foreground="#9692B8"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding DisplayValue}"
                                               FontSize="12" FontWeight="Bold"
                                               Foreground="{Binding ValueBrush}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Definition.Unit}"
                                               FontSize="10" Foreground="#8E8AB0"
                                               FontWeight="Medium"
                                               VerticalAlignment="Bottom" Margin="4,0,0,1"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>

<Window x:Class="Pulse.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Pulse.ViewModels"
        Title="Pulse Overlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Icon="pack://application:,,,/Resources/Icons/pulse.ico"
        SizeToContent="WidthAndHeight">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <FontFamily x:Key="Ubuntu">pack://application:,,,/Resources/Fonts/#Ubuntu</FontFamily>
        <FontFamily x:Key="UbuntuMedium">pack://application:,,,/Resources/Fonts/#Ubuntu Medium</FontFamily>
        <FontFamily x:Key="UbuntuBold">pack://application:,,,/Resources/Fonts/#Ubuntu Bold</FontFamily>
        <FontFamily x:Key="UbuntuLight">pack://application:,,,/Resources/Fonts/#Ubuntu Light</FontFamily>
    </Window.Resources>

    <Border x:Name="DragBorder" Padding="4">
        <Grid>
            <!-- ═══ NORMAL MODE ═══ -->
            <Border x:Name="NormalPanel" CornerRadius="14"
                    MinWidth="280" MaxWidth="320"
                    BorderThickness="1">
                <Border.BorderBrush>
                    <SolidColorBrush Color="#8B5CF6" Opacity="0.15"/>
                </Border.BorderBrush>
                <Border.Background>
                    <SolidColorBrush Color="#0B0D1A" Opacity="0.95"/>
                </Border.Background>

                <StackPanel Margin="14,12,14,10">
                    <!-- Header -->
                    <Grid Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="7" Height="7" Margin="0,0,7,0" VerticalAlignment="Center">
                                <Ellipse.Fill>
                                    <SolidColorBrush Color="{Binding StatusColor}"/>
                                </Ellipse.Fill>
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.9"
                                                      Color="{Binding StatusColor}"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <TextBlock Text="PULSE" FontSize="11" FontWeight="Bold"
                                       FontFamily="{StaticResource UbuntuBold}"
                                       Foreground="#A78BFA" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- Subtle gradient divider -->
                    <Border Height="1" Margin="0,0,0,10">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#8B5CF6" Offset="0"/>
                                <GradientStop Color="#1C1E3A" Offset="0.5"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Sensor tiles — 2 column grid -->
                    <ItemsControl ItemsSource="{Binding ActiveTiles}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:TileViewModel}">
                                <Border CornerRadius="10" Margin="3,3" Padding="12,8,12,9"
                                        BorderThickness="1">
                                    <Border.Background>
                                        <SolidColorBrush Color="#10122A"/>
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <SolidColorBrush Color="#1C1E3A"/>
                                    </Border.BorderBrush>
                                    <StackPanel>
                                        <!-- Label row -->
                                        <TextBlock Text="{Binding Definition.Label}"
                                                   FontSize="10" FontWeight="Medium"
                                                   FontFamily="{StaticResource UbuntuMedium}"
                                                   Foreground="#6B6D8A" Margin="0,0,0,4"/>
                                        <!-- Value + Unit row -->
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                                            <TextBlock Text="{Binding DisplayValue}"
                                                       FontSize="22" FontWeight="Bold"
                                                       FontFamily="{StaticResource UbuntuBold}"
                                                       Foreground="{Binding ValueBrush}"/>
                                            <TextBlock FontSize="11" Foreground="#4A4C6A"
                                                       FontFamily="{StaticResource UbuntuLight}"
                                                       VerticalAlignment="Bottom" Margin="4,0,0,3">
                                                <Run Text="{Binding Definition.Unit, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Status bar -->
                    <Border Height="1" Margin="0,6,0,8">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#1C1E3A" Offset="0.5"/>
                                <GradientStop Color="#8B5CF6" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="5" Height="5" VerticalAlignment="Center" Margin="0,0,6,0">
                            <Ellipse.Fill>
                                <SolidColorBrush Color="{Binding StatusColor}"/>
                            </Ellipse.Fill>
                            <Ellipse.Effect>
                                <DropShadowEffect BlurRadius="5" ShadowDepth="0" Opacity="0.6"
                                                  Color="{Binding StatusColor}"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusBrush}"
                                   FontSize="10" FontStyle="Italic"
                                   FontFamily="{StaticResource Ubuntu}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ═══ COMPACT HUD MODE ═══ -->
            <Border x:Name="CompactPanel" CornerRadius="8" Visibility="Collapsed" MinWidth="160"
                    BorderThickness="1">
                <Border.BorderBrush>
                    <SolidColorBrush Color="#8B5CF6" Opacity="0.1"/>
                </Border.BorderBrush>
                <Border.Background>
                    <SolidColorBrush Color="#0B0D1A" Opacity="0.75"/>
                </Border.Background>

                <StackPanel Margin="12,8,12,6">
                    <!-- Compact header -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Ellipse Width="5" Height="5" Margin="0,0,5,0" VerticalAlignment="Center">
                            <Ellipse.Fill>
                                <SolidColorBrush Color="{Binding StatusColor}"/>
                            </Ellipse.Fill>
                        </Ellipse>
                        <TextBlock Text="PULSE" FontSize="8" FontWeight="Bold"
                                   FontFamily="{StaticResource UbuntuBold}"
                                   Foreground="#4A4C6A"/>
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding ActiveTiles}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:TileViewModel}">
                                <Grid Margin="0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="78"/>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Definition.Label}"
                                               FontSize="11" FontWeight="Medium"
                                               FontFamily="{StaticResource UbuntuMedium}"
                                               Foreground="#6B6D8A"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding DisplayValue}"
                                               FontSize="11" FontWeight="Bold"
                                               FontFamily="{StaticResource UbuntuBold}"
                                               Foreground="{Binding ValueBrush}"
                                               HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Definition.Unit}"
                                               FontSize="9" Foreground="#4A4C6A"
                                               FontFamily="{StaticResource Ubuntu}"
                                               VerticalAlignment="Bottom" Margin="4,0,0,1"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
